// SPMB SD 2026/2027 - Prisma Schema
// Database untuk manajemen siswa TK/PAUD/KB dan PPDB SD
// Sesuai format Dapodik (Data Pokok Pendidikan)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// MODEL: Lembaga PAUD (TK/PAUD/KB/RA)
// ============================================

model LembagaPaud {
  id              String     @id @default(cuid())
  namaLembaga     String
  npsn            String     @unique
  jenisLembaga    String     // TK, PAUD, KB, RA, SPS
  alamat          String
  desa            String
  kecamatan       String
  kabupaten       String     @default("Cirebon")
  provinsi        String     @default("Jawa Barat")
  penanggungJawab String?
  noTelp          String?
  email           String?
  statusAktif     Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  siswa       SiswaTK[]
  importLogs  ImportLog[]

  @@index([kecamatan])
  @@index([jenisLembaga])
}

// ============================================
// MODEL: Siswa TK/PAUD/KB (Format Dapodik)
// ============================================

model SiswaTK {
  id              String    @id @default(cuid())
  lembagaPaudId   String

  nipd            String?
  nisn            String?
  namaSiswa       String
  nik             String?
  tempatLahir     String?
  tanggalLahir    DateTime?
  jenisKelamin    String?   // L / P
  agama           String?

  alamat          String?
  rt              String?
  rw              String?
  dusun           String?
  kelurahan       String?
  kecamatan       String?
  kodePos         String?
  jenisTinggal    String?
  alatTransportasi String?

  telepon         String?
  hp              String?
  email           String?

  namaAyah        String?
  tahunLahirAyah  String?
  jenjangPendidikanAyah String?
  pekerjaanAyah   String?
  penghasilanAyah String?
  nikAyah         String?

  namaIbu         String?
  tahunLahirIbu   String?
  jenjangPendidikanIbu String?
  pekerjaanIbu    String?
  penghasilanIbu  String?
  nikIbu          String?

  namaWali        String?
  tahunLahirWali  String?
  jenjangPendidikanWali String?
  pekerjaanWali   String?
  penghasilanWali String?
  nikWali         String?

  rombel          String?
  tahunAjaran     String?
  tahunMasuk      String?

  penerimaKPS     String?
  noKPS           String?
  penerimaKIP     String?
  nomorKIP        String?
  namaDiKIP       String?
  nomorKKS        String?
  noRegAktaLahir  String?
  layakPIP        String?
  alasanPIP       String?

  kebutuhanKhusus String?
  sekolahAsal     String?
  anakKe          Int?
  noKK            String?
  beratBadan      Int?
  tinggiBadan     Int?
  lingkarKepala   Int?
  jmlSaudaraKandung Int?
  jarakRumahKm    Int?
  lintang         String?
  bujur           String?

  statusAktif     Boolean   @default(true)
  catatan         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lembagaPaud LembagaPaud @relation(fields: [lembagaPaudId], references: [id], onDelete: Cascade)

  @@index([lembagaPaudId])
  @@index([namaSiswa])
  @@index([nik])
  @@index([nisn])
  @@index([kecamatan])
  @@index([noKK])
}

// ============================================
// MODEL: Import Log (Riwayat Import CSV)
// ============================================

model ImportLog {
  id               String      @id @default(cuid())
  fileName         String
  sourceUrl        String
  lembagaPaudId    String
  totalRecords     Int         @default(0)
  importedRecords  Int         @default(0)
  failedRecords    Int         @default(0)
  failedDetails    String?
  status           String      @default("processing") // processing, completed, completed_with_errors, failed
  errorMessage     String?
  importedAt       DateTime    @default(now())
  completedAt      DateTime?

  lembagaPaud LembagaPaud @relation(fields: [lembagaPaudId], references: [id], onDelete: Cascade)

  @@index([lembagaPaudId])
  @@index([status])
  @@index([importedAt])
}

// ============================================
// MODEL: User (Petugas/Admin SPMB)
// ============================================

model User {
  uid         String   @id
  email       String   @unique
  nama        String
  role        String   @default("operator") // operator, admin
  schoolId    String?
  statusAktif Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School?  @relation(fields: [schoolId], references: [schoolId])
}

// ============================================
// MODEL: School (Sekolah SD Tujuan SPMB)
// ============================================

model School {
  schoolId      String       @id
  namaSekolah   String
  npsn          String       @unique
  jenjang       String       @default("SD")
  alamat        String
  desa          String
  kecamatan     String
  latitude      Float
  longitude     Float
  kuota         Int
  sisaKuota     Int
  statusAktif   Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  applicants    Applicant[]
  users         User[]

  @@index([kecamatan])
}

// ============================================
// MODEL: Announcement (Pengumuman SPMB)
// ============================================

model Announcement {
  announcementId  String   @id
  title           String
  content         String
  tahunAjaran     String
  statusPublikasi String   @default("draft") // draft, publish
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([statusPublikasi])
  @@index([tahunAjaran])
}

// ============================================
// MODEL: Applicant (Pendaftar SPMB)
// ============================================

model Applicant {
  applicantId       String   @id
  nomorPendaftaran  String   @unique
  nik               String
  nisn              String?
  namaSiswa         String
  tempatLahir       String?
  tanggalLahir      String?
  jenisKelamin      String?  // Laki-laki / Perempuan
  agama             String?
  alamat            String?
  desa              String?
  kecamatan         String?
  namaAyah          String?
  nikAyah           String?
  pekerjaanAyah     String?
  namaIbu           String?
  nikIbu            String?
  pekerjaanIbu      String?
  noHpOrtu          String
  schoolId          String
  namaSekolah       String?
  jalur             String   // domisili, afirmasi, mutasi, prestasi, zoning
  statusBerkas      String   @default("belum_lengkap") // lengkap, belum_lengkap, perlu_perbaikan
  statusPendaftaran String   @default("draft") // draft, terkirim, menunggu_verifikasi, perlu_perbaikan, terverifikasi, diterima, cadangan, tidak_diterima, sudah_daftar_ulang
  catatanOperator   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  documents         Document[]
  reregistrations   ReRegistration[]
  school            School     @relation(fields: [schoolId], references: [schoolId])

  @@index([schoolId])
  @@index([statusPendaftaran])
  @@index([nik])
}

// ============================================
// MODEL: Document (Dokumen Pendaftaran)
// ============================================

model Document {
  documentId      String   @id
  applicantId     String
  jenisDokumen    String
  fileUrl         String?
  statusVerifikasi String  @default("belum_diverifikasi")
  catatan         String?
  uploadedAt      DateTime @default(now())

  applicant       Applicant @relation(fields: [applicantId], references: [applicantId], onDelete: Cascade)

  @@index([applicantId])
}

// ============================================
// MODEL: ReRegistration (Daftar Ulang)
// ============================================

model ReRegistration {
  reRegistrationId  String   @id
  applicantId       String
  nomorPendaftaran  String
  statusDaftarUlang String   @default("menunggu_verifikasi")
  dataSiswaLengkap  Boolean  @default(false)
  dokumenLengkap    Boolean  @default(false)
  catatanOperator   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  applicant         Applicant @relation(fields: [applicantId], references: [applicantId], onDelete: Cascade)

  @@index([applicantId])
}

// ============================================
// MODEL: Chat AI Settings (Pengaturan Chat AI)
// ============================================

model ChatAISettings {
  id                      String   @id @default(cuid())
  modelAI                 String   @default("gemini-2.0-flash") // Model AI yang digunakan
  aktifkanGoogleSearch    Boolean  @default(true) // Aktifkan pencarian Google
  aktifkanSlowTyping      Boolean  @default(true) // Aktifkan efek slow typing
  kecepatanTyping         String   @default("normal") // lambat, normal, cepat
  maksimalHasilGoogle    Int      @default(5) // Maksimal hasil Google (3-5)
  sumberUtama             String   @default("data_aplikasi") // Sumber utama jawaban
  sumberTambahan          String   @default("google_search") // Sumber tambahan
  systemPrompt            String?  // Prompt sistem AI kustom
  pesanFallback           String   @default("Maaf, saya tidak dapat memproses pertanyaan Anda saat ini. Silakan coba lagi atau hubungi panitia SPMB.") // Pesan fallback jika AI gagal
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())
}

// ============================================
// MODEL: Chat Analysis Log (Hasil Analisa Chat)
// ============================================

model ChatAnalysisLog {
  id                        String   @id @default(cuid())
  parentId                  String?  // ID pesan induk (chat log)
  pertanyaan                String   // Pertanyaan pengguna
  kategoriPertanyaan        String   // Kategori: info_spmb, usia_anak, domisili, pendaftaran, status_daftar, pengumuman, daftar_ulang, keluhan, umum
  sumberJawaban             String   // data_aplikasi, google_search, gabungan
  menggunakanDataAplikasi   Boolean  @default(false)
  menggunakanGoogleSearch   Boolean  @default(false)
  queryGoogle               String?  // Query pencarian Google
  hasilRingkasanGoogle      String?  // Ringkasan hasil Google
  jawabanAkhir              String?  // Jawaban akhir yang diberikan
  model                     String   @default("gemini-2.0-flash")
  waktuAnalisa              Int?     // Waktu analisa dalam ms
  createdAt                 DateTime @default(now())

  @@index([kategoriPertanyaan])
  @@index([sumberJawaban])
  @@index([createdAt])
}

// ============================================
// MODEL: Chat Log (Riwayat Chat)
// ============================================

model ChatLog {
  id              String   @id @default(cuid())
  parentId        String?  // ID pesan induk
  role            String   // user, ai
  content         String   // Isi pesan
  menu            String?  // Menu terkait
  typingMode      String   @default("slow") // slow, instant
  typingSpeed     String   @default("normal") // lambat, normal, cepat
  sourceType      String?  // data_aplikasi, google_search, gabungan
  analysisId      String?  // FK ke ChatAnalysisLog
  model           String   @default("gemini-2.0-flash")
  createdAt       DateTime @default(now())

  @@index([role])
  @@index([createdAt])
}
